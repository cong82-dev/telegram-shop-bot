# ================================================
# Starizzi Shop Bot - Cấu hình môi trường
# ================================================
# Copy file này thành .env và điền thông tin:
#   cp .env.example .env
# ================================================

# Telegram Bot Token (lấy từ @BotFather trên Telegram)
BOT_TOKEN=your_bot_token_here

# Admin Telegram ID (gửi /myid cho bot để lấy ID)
ADMIN_ID=your_telegram_id_here

# ================================================
# Ngân hàng 1 (bắt buộc) - Thanh toán QR VietQR
# ================================================
# Tra mã BIN tại: https://www.vietqr.io/danh-sach-ngan-hang
BANK_BIN=970422
BANK_ACCOUNT=your_bank_account_number
BANK_ACCOUNT_NAME=YOUR_FULL_NAME
BANK_NAME=MB

